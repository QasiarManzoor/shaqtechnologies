{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "shaqtechnologies",
  "compatibility_date": "2026-03-30",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "shaqtechnologies.com",
      "custom_domain": true
    },
    {
      "pattern": "www.shaqtechnologies.com",
      "custom_domain": true
    }
  ]
}
